# Grok Voice API
XAI_API_KEY=your-xai-api-key

# OpenAI for analysis
OPENAI_API_KEY=your-openai-api-key

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sales_coach

# S3 Storage (optional - uses local filesystem if not set)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_RECORDINGS_BUCKET=sales-coach-recordings

# Local storage fallback
LOCAL_RECORDINGS_PATH=./recordings

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
